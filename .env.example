# ── PostgreSQL ──────────────────────────────────────────────────────────────
# Имя пользователя PostgreSQL
POSTGRES_USER=

# Пароль пользователя PostgreSQL
POSTGRES_PASSWORD=

# Название базы данных
POSTGRES_DB=

# Порт PostgreSQL-сервера
POSTGRES_PORT=5432

# IP-адрес PostgreSQL-сервера
POSTGRES_IP=

# Строка подключения (используется Prisma и приложением)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public"

# ── S3-совместимое хранилище ──────────────────────────────────────────────
# Хост S3-сервиса (без протокола), например: s3.amazonaws.com или s3.example.ru
S3_ENDPOINT=

# Регион (для AWS — например us-east-1; для non-AWS совместимых — default)
S3_REGION=

# Название бакета (должен быть публичным на чтение)
S3_BUCKET=

# Ключ доступа
S3_ACCESS_KEY_ID=

# Секретный ключ
S3_SECRET_ACCESS_KEY=

# ── NextAuth ─────────────────────────────────────────────────────────────────
# Случайная строка для подписи JWT-сессий
# Сгенерировать: openssl rand -base64 32
NEXTAUTH_SECRET=

# Публичный URL приложения (без слеша в конце)
NEXT_PUBLIC_SITE_URL=https://your-domain.com
NEXTAUTH_URL=https://your-domain.com

# ── GitHub OAuth App ─────────────────────────────────────────────────────────
# Создать на https://github.com/settings/developers → OAuth Apps
# Callback URL: https://your-domain.com/api/auth/callback/github
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Email(ы) администраторов через запятую
ADMIN_ALLOWLIST=your@email.com

# ── Analytics (опционально) ──────────────────────────────────────────────────
# Google Analytics 4 Measurement ID (формат: G-XXXXXXXXXX). Оставьте пустым чтобы отключить.
NEXT_PUBLIC_GA_ID=

# Яндекс Метрика: числовой ID счётчика (например 12345678). Оставьте пустым чтобы отключить.
NEXT_PUBLIC_YM_ID=
