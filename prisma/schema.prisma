generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Photo {
  id          String       @id @default(cuid())
  s3Key       String       @unique
  publishedAt DateTime     @default(now())
  shotAt      DateTime?
  exifData    Json?
  albums      PhotoAlbum[]
  tags        PhotoTag[]
}

model Album {
  id          String       @id @default(cuid())
  name        String       @unique
  title       String
  description String?
  isSpecial   Boolean      @default(false)
  photos      PhotoAlbum[]
}

model Tag {
  id          String     @id @default(cuid())
  name        String     @unique
  title       String
  description String?
  photos      PhotoTag[]
}

model PhotoAlbum {
  photoId String
  albumId String
  photo   Photo  @relation(fields: [photoId], references: [id], onDelete: Cascade)
  album   Album  @relation(fields: [albumId], references: [id], onDelete: Cascade)

  @@id([photoId, albumId])
}

model PhotoTag {
  photoId String
  tagId   String
  photo   Photo @relation(fields: [photoId], references: [id], onDelete: Cascade)
  tag     Tag   @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([photoId, tagId])
}
